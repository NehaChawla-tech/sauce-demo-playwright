  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "typescript": "^5.6.2",
    "ts-node": "^10.9.2",
    "eslint": "^9.9.1",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "prettier": "^3.3.3"
  }
}